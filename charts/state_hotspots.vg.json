{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  
    "width": 650,
    "height": 350,
    "title": "Australian states with the most seabird observations",
  
    "data": {
      "url": "data/seabirds.csv",
      "format": {"type": "tsv"}
    },
  
    "mark": "bar",
  
    "encoding": {
      "y": {
        "field": "stateProvince",
        "type": "nominal",
        "sort": "-x",
        "title": "State / territory"
      },
  
      "x": {
        "aggregate": "count",
        "type": "quantitative",
        "title": "Number of observations"
      },
  
      "color": {
        "field": "stateProvince",
        "type": "nominal",
        "legend": null
      },
  
      "tooltip": [
        {"field": "stateProvince"},
        {"aggregate": "count", "type": "quantitative", "title": "Observations"}
      ]
    }
  }