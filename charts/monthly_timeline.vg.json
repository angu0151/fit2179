{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  
    "width": 700,
    "height": 350,
    "title": "When are migratory seabirds observed in Australia?",
  
    "data": {
      "url": "data/seabirds.csv",
      "format": {"type": "tsv"}
    },
  
    "mark": {
      "type": "line",
      "point": true
    },
  
    "encoding": {
      "x": {
        "field": "month",
        "type": "ordinal",
        "title": "Month"
      },
  
      "y": {
        "aggregate": "count",
        "type": "quantitative",
        "title": "Number of observations"
      },
  
      "color": {
        "field": "species",
        "type": "nominal",
        "title": "Species"
      },
  
      "tooltip": [
        {"field": "species"},
        {"field": "month"},
        {"aggregate": "count", "type": "quantitative", "title": "Observations"}
      ]
    }
  }