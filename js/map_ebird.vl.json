{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "eBird weekly abundance map \u2014 all 4 species. Filter by week using selectedWeek signal.",
  "width": 820,
  "height": 420,
  "projection": {
    "type": "equalEarth"
  },
  "params": [
    {
      "name": "selectedWeek",
      "value": "2023-01-04"
    },
    {
      "name": "showSpecies1",
      "value": true
    },
    {
      "name": "showSpecies2",
      "value": true
    },
    {
      "name": "showSpecies3",
      "value": true
    },
    {
      "name": "showSpecies4",
      "value": true
    }
  ],
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/2_symbol_map/js/ne_110m_admin_0_countries.topojson",
        "format": {
          "type": "topojson",
          "feature": "ne_110m_admin_0_countries"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#1a2436",
        "stroke": "#253145",
        "strokeWidth": 0.4
      }
    },
    {
      "data": {
        "url": "../data/ebird_all.csv"
      },
      "transform": [
        {
          "filter": "datum.week === selectedWeek"
        },
        {
          "filter": "(datum.species_id === 1 && showSpecies1) || (datum.species_id === 2 && showSpecies2) || (datum.species_id === 3 && showSpecies3) || (datum.species_id === 4 && showSpecies4)"
        }
      ],
      "mark": {
        "type": "circle",
        "opacity": 0.75,
        "filled": true
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "color": {
          "field": "species",
          "type": "nominal",
          "scale": {
            "domain": [
              "Grey Plover",
              "Barn Swallow",
              "Upland Sandpiper",
              "Red Knot"
            ],
            "range": [
              "#e8a87c",
              "#5ba4cf",
              "#57a773",
              "#b07fd4"
            ]
          },
          "title": "Species"
        },
        "size": {
          "field": "abundance",
          "type": "quantitative",
          "scale": {
            "range": [
              8,
              350
            ]
          },
          "legend": null
        },
        "tooltip": [
          {
            "field": "species",
            "type": "nominal",
            "title": "Species"
          },
          {
            "field": "week",
            "type": "nominal",
            "title": "Week"
          },
          {
            "field": "longitude",
            "type": "quantitative",
            "title": "Longitude",
            "format": ".2f"
          },
          {
            "field": "latitude",
            "type": "quantitative",
            "title": "Latitude",
            "format": ".2f"
          },
          {
            "field": "abundance",
            "type": "quantitative",
            "title": "Abundance",
            "format": ".2f"
          }
        ]
      }
    }
  ],
  "config": {
    "background": "#161c27",
    "view": {
      "stroke": null
    },
    "axis": {
      "gridColor": "#253145",
      "labelColor": "#64748b",
      "titleColor": "#64748b"
    },
    "legend": {
      "labelColor": "#64748b",
      "titleColor": "#64748b"
    }
  }
}